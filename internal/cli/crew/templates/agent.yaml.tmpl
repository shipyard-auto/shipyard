schema_version: "{{.SchemaVersion}}"
name: {{.Name}}
description: "replace me — describe what this agent does"

backend:
  type: {{.BackendType}}
{{- if eq .BackendType "cli" }}
  # {{"{{.Prompt}}"}} is expanded at run time with the contents of prompt.md.
  # Use {{"{{.PromptFile}}"}} instead if your CLI prefers a file path.
  command: ["claude", "--print", "--append-system-prompt", "{{"{{.Prompt}}"}}"]
{{- else }}
  model: claude-sonnet-4-6
{{- end }}

execution:
  mode: {{.Mode}}
  pool: cli

conversation:
  mode: stateless

triggers: []

tools: []
